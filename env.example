# ─────────────────────────────────────────
# LLM API 키 설정
# ─────────────────────────────────────────
# 이 파일을 복사해서 .env 로 저장 후 키를 입력하세요
# .env 파일은 절대 GitHub에 올리지 마세요 (.gitignore에 등록되어 있음)

# Anthropic Claude API 키 (Primary — 필수)
# 발급: https://console.anthropic.com
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# OpenAI API 키 (Secondary / 폴백 — 선택)
# 발급: https://platform.openai.com
OPENAI_API_KEY=your-openai-api-key-here
